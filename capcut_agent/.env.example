# CapCut 음악 편집기 로컬 설정 (이 파일을 .env 로 복사해서 사용하세요)
# 이 파일은 Git에 커밋되지만, 복사해서 생성한 .env 파일은 Git에 커밋되지 않습니다.

# 음악 파일이 있는 폴더 경로
MUSIC_FOLDER=C:\Users\Sung\YouTube-Playlist\Contents\0604

# 배경 이미지 폴더 경로 (없으면 None 또는 비워두세요)
IMAGES_FOLDER=C:\Users\Sung\YouTube-Playlist\Contents\0604

# CapCut 초안 폴더 경로
# 기본 Windows 경로: C:\Users\<사용자명>\AppData\Local\CapCut\User Data\Projects\com.lveditor.draft
CAPCUT_DRAFT_FOLDER=C:\Users\Sung\AppData\Local\CapCut\User Data\Projects\com.lveditor.draft

# 생성할 초안 이름
DRAFT_NAME=Girl Smile4
