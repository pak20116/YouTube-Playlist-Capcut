# ───────────────────────────────────────────────
#  Suno Agent 환경변수 설정
#  이 파일을 복사해서 .env 로 저장하고 값을 채우세요
# ───────────────────────────────────────────────

# [필수] Anthropic Claude API 키 (프롬프트 자동 생성용)
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# [선택] gcui-art/suno-api 서버 URL
# API 방식 사용 시: git clone https://github.com/gcui-art/suno-api && npm run dev
SUNO_API_BASE_URL=http://localhost:3000

# [선택] Suno 계정 쿠키 (API 방식 또는 브라우저 방식 모두에서 필요)
# 취득 방법:
#   1. suno.com/create 접속
#   2. F12 → Network 탭 → 페이지 새로고침
#   3. ?__clerk_api_version 포함된 요청 클릭 → Headers → Cookie 값 복사
SUNO_COOKIE=__client=...
